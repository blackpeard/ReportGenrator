### Use engine directly in your own script
```python
from report_engine import ReportEngine, ReportConfig

config = ReportConfig(
    client_name  = "Acme Bank Pvt. Ltd.",
    app_name     = "Internet Banking Portal",
    app_type     = "External Web Application",
    audit_period = "01-01-2026 - 15-01-2026",
    url          = "https://banking.acme.com",
    method       = "Grey Box",
    report_type  = "Web",        # Web | Api | Mobile
    environment  = "Production", # Production | Uat
    excel_file   = "findings.xlsx",
    poc_folder   = "poc/",
    output_file  = "report.docx",
)

engine = ReportEngine(
    config,
    progress_callback=lambda pct: print(f"{pct}%"),
    log_callback=print,
)
result = engine.run()

if result.success:
    print(f"Saved to: {result.output_path}")
```

